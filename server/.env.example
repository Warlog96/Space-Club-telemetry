# Server Configuration
PORT=3001
WS_PORT=3000

# MQTT Broker Configuration
# For local development: mqtt://localhost:1883
# For production: Use a cloud MQTT broker or leave empty to rely on Firebase only
MQTT_BROKER=mqtt://localhost:1883
MQTT_TOPIC=rocket/telemetry

# CORS Configuration
# Add your deployed frontend URL here (e.g., https://your-app.vercel.app)
FRONTEND_URL=http://localhost:5174

# Firebase Admin SDK
# Note: In production, use Railway's service account key upload feature
# or set FIREBASE_SERVICE_ACCOUNT as a JSON string environment variable
