# WebSocket URL - Replace with your deployed Railway backend URL
# Format: wss://your-backend.railway.app (use wss:// for secure WebSocket)
VITE_WS_URL=wss://your-backend.railway.app

# API URL - Replace with your deployed Railway backend URL
# Format: https://your-backend.railway.app
VITE_API_URL=https://your-backend.railway.app
